apiVersion: chaos-mesh.org/v1alpha1
kind: TimeChaos
metadata:
  name: time-skew-{{.RunID}}
  namespace: {{.Namespace}}
  labels:
    sei.io/harness-run: "{{.RunID}}"
spec:
  # Skew one validator's clock -30s; the chain stays live because that validator
  # (1/4 power) is outvoted on CometBFT's median-vote block time, not because the
  # skew is within a per-vote tolerance.
  mode: one
  selector:
    namespaces: ["{{.Namespace}}"]
    expressionSelectors:
      - {key: sei.io/nodedeployment, operator: In, values: ["{{.ChainID}}"]}
  timeOffset: "-30s"
  clockIds: ["CLOCK_REALTIME"]
  containerNames: ["seid"]
  duration: "{{.Duration}}"
