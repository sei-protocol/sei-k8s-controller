apiVersion: chaos-mesh.org/v1alpha1
kind: StressChaos
metadata:
  name: cpu-stress-{{.RunID}}
  namespace: {{.Namespace}}
  labels:
    sei.io/harness-run: "{{.RunID}}"
spec:
  # Saturate CPU on one validator; the chain must keep producing on the rest.
  mode: one
  selector:
    namespaces: ["{{.Namespace}}"]
    expressionSelectors:
      - {key: sei.io/nodedeployment, operator: In, values: ["{{.ChainID}}"]}
  stressors:
    cpu:
      workers: 4
      load: 80
  duration: "{{.Duration}}"
