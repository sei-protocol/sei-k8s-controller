apiVersion: sei.io/v1alpha1
kind: SeiNodeTask
metadata:
  name: PLACEHOLDER
spec:
  kind: GovVote
  target:
    nodeRef:
      name: {{ .NODE }}
  timeoutSeconds: {{ with index . "TIMEOUT_SECONDS" }}{{ . }}{{ else }}300{{ end }}
  govVote:
    chainId: {{ .CHAIN_ID }}
    {{- with index . "KEY_NAME" }}
    keyName: {{ . }}
    {{- end }}
    proposalId: {{ .PROPOSAL_ID }}
    option: {{ .OPTION }}
    fees: {{ .FEES }}
    gas: {{ .GAS }}
