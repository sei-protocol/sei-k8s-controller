apiVersion: sei.io/v1alpha1
kind: SeiNetwork
metadata:
  name: PLACEHOLDER
spec:
  image: "{{ .IMAGE }}"
  replicas: 4
  configOverrides:
    tx_index.indexer: kv
    storage.state_commit.write_mode: memiavl_only
    storage.state_store.write_mode: memiavl_only
    mempool.ttl_duration: 60s
  genesis:
    chainId: "{{ .CHAIN_ID }}"
    accounts:
      - address: "{{ .ADMIN_ADDRESS }}"
        balance: 1000000000000usei
