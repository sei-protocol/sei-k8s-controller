apiVersion: sei.io/v1alpha1
kind: SeiNodeDeployment
metadata:
  name: PLACEHOLDER
spec:
  replicas: 2
  template:
    spec:
      chainId: "{{ .CHAIN_ID }}"
      image: "{{ .IMAGE }}"
      fullNode: {}
      peers:
        - label:
            selector:
              sei.io/chain: "{{ .CHAIN_ID }}"
      overrides:
        tx_index.indexer: kv
        storage.state_commit.write_mode: memiavl_only
        storage.state_store.write_mode: memiavl_only
  updateStrategy:
    type: InPlace
