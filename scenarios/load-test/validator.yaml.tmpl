apiVersion: sei.io/v1alpha1
kind: SeiNodeDeployment
metadata:
  name: PLACEHOLDER
spec:
  replicas: 4
  template:
    spec:
      chainId: "{{ .CHAIN_ID }}"
      image: "{{ .IMAGE }}"
      validator: {}
      overrides:
        storage.state_commit.write_mode: memiavl_only
        storage.state_store.write_mode: memiavl_only
  genesis:
    chainId: "{{ .CHAIN_ID }}"
  updateStrategy:
    type: InPlace
